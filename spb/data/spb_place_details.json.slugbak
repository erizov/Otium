{
  "winter_palace": {
    "address": "Дворцовая набережная, 38 (Государственный Эрмитаж)",
    "year_built": "1754–1762 (елизаветинский объём), последующие достройки",
    "architecture_style": "елизаветинское барокко, классицизм",
    "description": "Главный императорский дворец Российской империи; сегодня — ядро музейного комплекса Эрмитажа. Фасад длиной около двухсот метров задаёт масштаб Дворцовой площади и набережной Невы.",
    "history": "Строительство вёлось при Елизавете Петровне и Екатерине II; Растрелли и последующие архитекторы формировали ансамбль вокруг прежних застроек. После пожара 1837 года интерьеры частично восстанавливались; в 1917 году здесь находилось Временное правительство.",
    "significance": "Символ императорской власти и мирового уровня художественных коллекций; объект культурного наследия и одно из узнаваемых лиц Санкт-Петербурга.",
    "facts": [
      "В ансамбль входят здания на Дворцовой набережной и в глубине квартала — общая экспозиция Эрмитажа рассчитана на многодневное посещение.",
      "Зелёно-белая гамма фасада хорошо читается с воды и с Александровской колонны."
    ],
    "stories": [
      "Говорят, масштаб фасада задумывали так, чтобы дворец уравновешивал панораму набережной и не терялся на фоне открытого неба Невы."
    ]
  },
  "kazan_cathedral": {
    "address": "Казанская площадь, 2",
    "year_built": "1801–1811",
    "architecture_style": "русский ампир, отсылка к собору Св. Петра в Риме",
    "description": "Главный храм Казанской иконы Божией Матери на Невском проспекте; колоннада с полукружием делает храм одним из самых узнаваемых силуэтов города.",
    "history": "Возведён по проекту А. Н. Воронихина на месте каменной церкви; после революции здание использовалось не только как культовое. Возвращено верующим в 1990-х; ведутся службы и экскурсии.",
    "significance": "Архитектурная доминанта Невского проспекта и важная точка городской религиозной жизни.",
    "facts": [
      "Колоннад из двадцати четырёх коринфских полуколонн окружает центральный объём.",
      "Внутри хранятся списки с чудотворной Казанской иконы."
    ],
    "stories": []
  },
  "savior_on_blood": {
    "address": "наб. канала Грибоедова, 2Б",
    "year_built": "1883–1907",
    "architecture_style": "русский стиль, мозаики и «шатровый» силуэт",
    "description": "Храм-памятник на месте смертельного ранения императора Александра II; пять луковичных глав и насыщенный декор делают его контрастом к классическим ансамблям центра.",
    "history": "Строительство длилось более двух десятилетий; интерьеры украшены мозаикой по эскизам Ф. Г. Бруни, В. М. Васнецова и других художников. В советское время музей; с 1990-х — действующий храм.",
    "significance": "Один из самых посещаемых памятников «русского» направления в архитектуре Петербурга.",
    "facts": [
      "Ни одного гвоздя в деревянной конструкции кровли — соединения на шпонках.",
      "Площадь мозаик внутри — одна из крупнейших в Европе для храмовой архитектуры."
    ],
    "stories": [
      "Название «на Крови» закрепилось из-за трагического события 1881 года; сам памятник задумывался как молитва о мире и урок для потомков."
    ]
  },
  "peter_paul_fortress": {
    "address": "Заячий остров",
    "year_built": "1703–1740-е (ядро крепости), далее перестройки",
    "architecture_style": "фортификация петровского времени, позже классицизм",
    "description": "Место основания города и историческая тюрьма; собор Святых Петра и Павла с золочёным шпилем задаёт высотную отметку города.",
    "history": "Заложена Петром I; долгое время служила политической тюрьмой. Петропавловский собор — усыпальница многих императоров. Крепостные валы и бастионы сохраняют силуэт «короны» на Неве.",
    "significance": "Точка отсчёта истории Санкт-Петербурга и память о династии Романовых.",
    "facts": [
      "Шпиль собора увенчан фигурой ангела — один из символов города.",
      "Ежегодно в день основания на Неве открывают разводные мосты для прохода крейсера «Аврора» и военных кораблей."
    ],
    "stories": []
  },
  "admiralty_spb": {
    "address": "Дворцовая набережная, 2",
    "year_built": "1806–1823 (классический корпус А. Д. Захарова)",
    "architecture_style": "русский классицизм",
    "description": "Штаб российского флота и архитектурная ось «трёх улиц» — Невского, Гороховой и Вознесенского проспектов сходятся к золочёному шпилю.",
    "history": "Петровская верфь выросла в адмиралтейский комплекс; нынешний ансамбль связан с именем Захарова. Шпиль с кораблём на флюгере стал визитной карточкой панорамы с воды.",
    "significance": "Символ морской силы империи и градостроительный центр исторического Петербурга.",
    "facts": [
      "Длина золочёного шпиля около семидесяти двух метров.",
      "Три луча проспектов формируют редкий для Европы пример радиальной планировки от одного фасада."
    ],
    "stories": [
      "Городская легенда связывает строгость проспектов с желанием «видеть корабль с каждой центральной улицы» — скорее поэтический образ, чем документ."
    ]
  },
  "bronze_horseman": {
